{
  "name": "openclaw-command-deck",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone dashboard for a local OpenClaw instance",
  "packageManager": "npm@10.9.3",
  "scripts": {
    "dev": "next dev",
    "dev:test": "next dev --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/unit",
    "test:e2e": "playwright test"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.1",
    "@typescript-eslint/parser": "^8.57.2",
    "@types/node": "^22.15.30",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.8",
    "eslint": "^9.25.1",
    "eslint-config-next": "^15.3.0",
    "typescript": "^5.8.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.1.3"
  }
}
